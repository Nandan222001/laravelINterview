# Application Configuration
APP_NAME="Payment API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=payment_api
DB_USERNAME=root
DB_PASSWORD=

# Redis Configuration (for cache, queues, and rate limiting)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=payment_api

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Queue Configuration
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database

# Broadcasting
BROADCAST_DRIVER=redis

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
RAZORPAY_API_URL=https://api.razorpay.com/v1
RAZORPAY_TIMEOUT=30
RAZORPAY_RETRY_ATTEMPTS=3
RAZORPAY_RETRY_DELAY=1000

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_API_URL=https://api.stripe.com/v1
STRIPE_TIMEOUT=30
STRIPE_API_VERSION=2023-10-16

# PayPal Configuration
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_MODE=sandbox
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=xxx

# Security Configuration
BCRYPT_ROUNDS=12
HASHING_DRIVER=argon2id

# CORS Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,example.com
FRONTEND_URL=https://example.com

# Rate Limiting
RATE_LIMIT_API=60
RATE_LIMIT_LOGIN=5
RATE_LIMIT_PAYMENT=5

# Monitoring & Error Tracking
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Notification Services
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#payments
SLACK_USERNAME="Payment Bot"

# Email Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SMS Configuration
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# AWS Configuration (S3, SES, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=

# Google Cloud Platform
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_KEY_FILE=
GOOGLE_CLOUD_STORAGE_BUCKET=

# Security Headers
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true
X_FRAME_OPTIONS=DENY

# API Configuration
API_VERSION=v1
API_RATE_LIMIT=60
API_PAGINATION_LIMIT=100

# Idempotency Configuration
IDEMPOTENCY_KEY_EXPIRY_DAYS=7
IDEMPOTENCY_CACHE_TTL=86400

# Payment Configuration
PAYMENT_CAPTURE_MODE=auto
PAYMENT_CURRENCY_DEFAULT=USD
PAYMENT_MIN_AMOUNT=0.50
PAYMENT_MAX_AMOUNT=999999.99
PAYMENT_REFUND_WINDOW_DAYS=90

# Feature Flags
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_PAYMENT_ANALYTICS=true
FEATURE_AUTO_REFUND=false

# Development & Testing
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

# Analytics
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=

# Datadog APM
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SERVICE_NAME=payment-api

# New Relic
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME="Payment API"

# Cloudflare
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=

# reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_VERSION=v3
