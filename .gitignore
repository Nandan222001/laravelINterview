# Interview Bank - .gitignore

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor and IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-debug.log*

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Testing
coverage/
*.lcov
.nyc_output
__tests__/__snapshots__/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# PHP/Laravel
vendor/
composer.lock
.phpunit.result.cache
storage/logs/*.log
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*

# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Docker
.docker/
docker-compose.override.yml

# Cloud credentials
credentials.json
service-account.json
*.pem
*.key
*.cert

# Secrets and sensitive data
secrets/
.secrets
*-secret.yaml
*-secrets.yaml

# Generated documentation (if not needed in repo)
# Uncomment if you generate docs locally
# docs/_build/
# site/

# Backup files
*.bak
*.backup
*.old

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Database
*.sqlite
*.db
*.sql

# Personal notes (optional - uncomment if you want to keep personal notes out of repo)
# NOTES.md
# TODO.md
# PERSONAL.md

# Automation output (generated files)
automation/output/
automation/*.html
automation/*.json
automation/*.md
!automation/README.md
!automation/IMPLEMENTATION.md
!automation/HTML_GENERATOR_GUIDE.md
!automation/EXAMPLE_OUTPUT.md

# PDF Generator - TCPDF
pdf-exports/
*.pdf
!nandan_singh_resume.pdf

# PWA Icons (generated)
icons/*.png
!icons/README.md
!icons/generate-icons.html

# PWA Screenshots
screenshots/
